PROD_WEBSITE_URL=
STAGE_WEBSITE_URL=
# JSON map: scope + item selectors (see selector-maps/). Use a map with postNavigationWait for migrated Next.js (hydration).
SELECTOR_MAP_PATH=
VERCEL_AUTOMATION_BYPASS_SECRET=
PIXEL_MATCH_THRESHOLD= # 0.0 to 1.0, lower is more strict

UNIFORM_API_KEY=
UNIFORM_PROJECT_ID=

# png (default) or bmp — bmp is written via Sharp from Playwright’s PNG capture; diff still uses PNG internally for Resemble.
SCREENSHOT_FORMAT=

SITEMAP_URL=
# Pipe-separated path patterns; * = one segment. Only the first N URLs per pattern are kept (see SITEMAP_DYNAMIC_SAMPLE_COUNT); other paths stay as in the sitemap.
# Also used by build:urls:diff — URLs matching any pattern are excluded from the urls.json vs urls-sitemap.json diff.
# Example: /news/childrens-hospitals-today/*/*/*|/content/pediatric-learning-solutions/article/*|/news/newsroom/*/*/*|/news/cha-blog/*/*/*
SITEMAP_DYNAMIC_SAMPLE_PATTERNS=
# How many sample URLs to keep for each dynamic pattern (default 2).
SITEMAP_DYNAMIC_SAMPLE_COUNT=

VISUAL_REGRESSION_EXCLUDE_RESULTS=[{"url":"/self-regulation","component":"div-03","percents":0.09}]